# --- Agent Zero connection ---
# URL внутри Docker network: http://agent-zero:80
# URL с хоста: http://localhost:50080 (или порт который вы маппили)
A0_URL=http://agent-zero:80

# API key из Agent Zero Web UI: Settings -> External Services -> API Keys
A0_API_KEY=replace-me

# Версия Agent Zero. Допустимые значения: "v1" (для 1.2-1.20) или "v2" (для 2.0+)
A0_VERSION=v2

# Дефолтный проект (если не передан в инструменте). Может быть пустым.
A0_DEFAULT_PROJECT=

# Таймауты в секундах
A0_HTTP_TIMEOUT=30
A0_WAIT_TIMEOUT=600
A0_WAIT_POLL_INTERVAL=2.0

# --- MCP server ---
# Хост и порт для FastMCP streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8765

# Опциональный bearer token, который Claude Code должен прислать в Authorization header.
# Оставьте пустым в локальной dev-среде.
MCP_AUTH_TOKEN=

# Уровень логирования
LOG_LEVEL=INFO

# --- Agent Zero external API ---
# База БЕЗ /api. Пути формируются как {A0_URL}/api/api_message и т.д.
# ВАЖНО: порт — тот, на котором A0 реально отдаёт external API. Посмотрите готовый URL
# в WebUI: Settings -> External API (примеры там содержат точный адрес и порт).
# Внутри docker network: http://agent-zero:80 ; с хоста: http://<host>:<external-api-port>
A0_URL=http://agent-zero:80

# X-API-KEY. В A0 это тот же mcp_server_token (Settings -> External API / MCP).
A0_API_KEY=replace-me

# Дефолтный project_name (активируется на первом сообщении). Может быть пустым.
A0_DEFAULT_PROJECT=

# Таймауты, сек. api_message синхронный и держит соединение до ответа агента — нужен большой.
A0_HTTP_TIMEOUT=30
A0_MESSAGE_TIMEOUT=600
A0_LIFETIME_HOURS=24

# --- MCP server ---
MCP_HOST=0.0.0.0
MCP_PORT=8765

# Опциональный bearer token, который Claude Code должен прислать в Authorization header.
MCP_AUTH_TOKEN=

# DNS-rebinding защита MCP-транспорта. По умолчанию false — иначе доступ по LAN-адресу
# (не localhost) режется с 421 Misdirected Request. Включайте только вместе с
# MCP_ALLOWED_HOSTS / MCP_ALLOWED_ORIGINS (CSV, Host с портом; '*' — любой).
MCP_DNS_REBINDING_PROTECTION=false
MCP_ALLOWED_HOSTS=
MCP_ALLOWED_ORIGINS=

LOG_LEVEL=INFO
